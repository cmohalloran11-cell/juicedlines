# secrets / credentials — NEVER COMMIT
# config.json holds the live PrizePicks _px3 cookie (see config.example.json)
config.json
.env
*.key
secrets.json

# runtime data / databases (regenerated at runtime)
history.db
*.db
*.sqlite
*.sqlite3

# cached Sackmann-mirror CSVs (CC NON-COMMERCIAL — runtime cache, do not distribute)
tennis/data/cache/

# static build artifact (the GitHub Action rebuilds it and pushes it to the deploy branch)
static/board.json
static/board.free.json
static/board.premium.json
static/analytics.json
static/history.json
static/clv.db
# NB: clv_seed.db IS committed on purpose — it bootstraps the Action's ledger with the
# already-graded rows (the edge-regression asset). Only the build's working copy is ignored.

# python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.venv/
venv/
env/

# os / editor / tooling
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/
.claude/
